# ============================================
#  تنظیمات ربات مانیتور ایردراپ
#  این فایل رو به .env تغییر نام بده و پر کن
# ============================================

# فقط این یکی چیز لازم داری!
# از @BotFather در تلگرام بگیر
BOT_TOKEN=

# مسیر دیتابیس
# روی سیستم محلی: data.db (پیش‌فرض)
# روی Railway: از متغیر محیطی استفاده می‌شود
DATABASE_PATH=data.db

# فاصله بررسی منابع بر حسب ثانیه (پیش‌فرض: ۳۰۰ = ۵ دقیقه)
POLL_INTERVAL=300

# حداکثر طول متن برای ترجمه (کاراکتر)
MAX_TRANSLATE_LENGTH=4500

